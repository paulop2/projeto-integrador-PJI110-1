# backend/.env.example — copiar para .env e preencher valores reais
DATABASE_URL=sqlite:///./escola.db
SECRET_KEY=change-me-in-production-use-random-32-chars
ACCESS_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:5173"]
ENVIRONMENT=development

# SMTP — Mailtrap para desenvolvimento/demo
# Obtenha credenciais em: https://mailtrap.io/
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=seu_usuario_mailtrap
SMTP_PASS=sua_senha_mailtrap
SMTP_SENDER=noreply@escola.dev

# Frontend URL para links de redefinição de senha
FRONTEND_URL=http://localhost:5173
